---
---
{% assign blogs = site.pages | where: "layout", "blog" | sort: "blog_number" | reverse %}[
{% for blog in blogs %}
    {% assign blog_file = blog.path | split: "/" | last %}
    {% assign blog_counter = blog.blog_counter %}
    {% if forloop.first %}
        {% assign blog_counter = blog_counter | append: " (Newest)" %}
    {% endif %}
    {
        "id": {{ blog.blog_counter | downcase | replace: " #", "-" | jsonify }},
        "url": {{ blog_file | jsonify }},
        "counter": {{ blog_counter | jsonify }},
        "title": {{ blog.card_title | default: blog.title | remove: " | Rover" | jsonify }}
    }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
