---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
    {% unless page.url contains '.json' or page.url contains '.xml' or page.url contains '.txt' or page.url contains '.css' or page.url contains '.js' or page.sitemap == false %}
    <url>
      <loc>https://roverhq.ai{{ page.url | replace: 'index.html', '' }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <changefreq>{% if page.url == '/' or page.url == '/blogs/' %}daily{% else %}weekly{% endif %}</changefreq>
      <priority>{% if page.url == '/' %}1.0{% elsif page.url == '/blogs/' %}0.9{% elsif page.url contains '/blogs/' %}0.8{% else %}0.5{% endif %}</priority>
    </url>
    {% endunless %}
  {% endfor %}
</urlset>
